  <div class="modal" id="modal">
    <div class="modal-conteudo">
      <h3 id="modalTitulo">Vale ativado!</h3>
      <p id="modalTexto">
        Vale ativado com sucesso! Agora é só cobrar do seu amor ❤️
      </p>
      <button class="botao-principal" onclick="fecharModal()">Fechar</button>
    </div>
  </div>

  <script>
    /* =====================================================
       CORAÇÕES FLUTUANDO NA TELA INICIAL
       ===================================================== */

    function criarCoracoesFlutuantes() {
      const inicio = document.querySelector(".inicio");

      for (let i = 0; i < 22; i++) {
        const coracao = document.createElement("div");
        coracao.classList.add("coracao-flutuante");
        coracao.innerHTML = "❤";

        coracao.style.left = Math.random() * 100 + "%";
        coracao.style.animationDelay = Math.random() * 8 + "s";
        coracao.style.animationDuration = 6 + Math.random() * 5 + "s";
        coracao.style.fontSize = 16 + Math.random() * 26 + "px";

        inicio.appendChild(coracao);
      }
    }

    criarCoracoesFlutuantes();

    /* =====================================================
       20 COISAS QUE AMO EM VOCÊ
       EDITE AQUI OS TEXTOS DOS 20 CARDS
       ===================================================== */

    const coisasQueAmo = [
      "Amo o seu sorriso.",
      "Amo seu jeito de cuidar de mim.",
      "Amo quando você me faz rir.",
      "Amo estar com você.",
      "Amo seu olhar.",
      "Amo sua voz.",
      "Amo quando você fica toda carinhosa.",
      "Amo nossas conversas.",
      "Amo nossos momentos bobos.",
      "Amo o jeito que você me entende.",
      "Amo quando a gente cria memórias juntos.",
      "Amo sua companhia.",
      "Amo o seu abraço.",
      "Amo sua risada.",
      "Amo quando você me dá atenção.",
      "Amo seu jeitinho único.",
      "Amo como você deixa meus dias melhores.",
      "Amo sonhar com o futuro ao seu lado.",
      "Amo cada detalhe seu.",
      "Amo você por completo."
    ];

    const gridAmor = document.getElementById("gridAmor");
    const mensagemAmor = document.getElementById("mensagemAmor");

    coisasQueAmo.forEach((texto, index) => {
      const botao = document.createElement("button");
      botao.classList.add("botao-amor");
      botao.textContent = index + 1;

      botao.addEventListener("click", () => {
        mensagemAmor.textContent = texto + " ❤️";
        mensagemAmor.style.animation = "none";
        mensagemAmor.offsetHeight;
        mensagemAmor.style.animation = "aparecer 0.4s ease";
      });

      gridAmor.appendChild(botao);
    });

    /* =====================================================
       VALES DO AMOR
       ===================================================== */

    function usarVale(nomeVale) {
      document.getElementById("modalTitulo").textContent = nomeVale;
      document.getElementById("modalTexto").textContent =
        "Vale ativado com sucesso! Agora é só cobrar do seu amor ❤️";

      document.getElementById("modal").classList.add("ativo");
      criarExplosaoCoracoes();
    }

    function fecharModal() {
      document.getElementById("modal").classList.remove("ativo");
    }

    document.getElementById("modal").addEventListener("click", function(event) {
      if (event.target === this) {
        fecharModal();
      }
    });

    /* =====================================================
       QUIZ DO NOSSO AMOR
       EDITE AQUI:
       - Perguntas
       - Alternativas
       - Resposta correta
       
       A resposta correta começa contando do 0.
       Exemplo:
       correta: 0 significa primeira alternativa.
       correta: 1 significa segunda alternativa.
       ===================================================== */

    const perguntasQuiz = [
      {
        pergunta: "Onde foi nosso primeiro encontro?",
        opcoes: ["Lugar especial 1", "Lugar especial 2", "Lugar especial 3", "Lugar especial 4"],
        correta: 0
      },
      {
        pergunta: "Qual foi uma das nossas melhores memórias?",
        opcoes: ["Um passeio juntos", "Uma conversa aleatória", "Um dia engraçado", "Todas as opções"],
        correta: 3
      },
      {
        pergunta: "Quem é mais carinhoso?",
        opcoes: ["Você", "Eu", "Nós dois", "Depende do dia"],
        correta: 2
      },
      {
        pergunta: "Quem demora mais para responder mensagem?",
        opcoes: ["Você", "Eu", "Os dois", "Ninguém admite"],
        correta: 3
      },
      {
        pergunta: "Qual é nosso programa favorito juntos?",
        opcoes: ["Ver filme", "Comer algo", "Conversar", "Ficar juntinhos"],
        correta: 3
      }
    ];

    let perguntaAtual = 0;
    let pontuacaoQuiz = 0;

    const quizPergunta = document.getElementById("quizPergunta");
    const quizOpcoes = document.getElementById("quizOpcoes");
    const quizResultado = document.getElementById("quizResultado");

    function carregarPergunta() {
      const atual = perguntasQuiz[perguntaAtual];

      quizPergunta.textContent = atual.pergunta;
      quizOpcoes.innerHTML = "";
      quizResultado.textContent = "";

      atual.opcoes.forEach((opcao, index) => {
        const botao = document.createElement("button");
        botao.textContent = opcao;

        botao.addEventListener("click", () => {
          responderQuiz(index);
        });

        quizOpcoes.appendChild(botao);
      });
    }

    function responderQuiz(resposta) {
      if (resposta === perguntasQuiz[perguntaAtual].correta) {
        pontuacaoQuiz++;
      }

      perguntaAtual++;

      if (perguntaAtual < perguntasQuiz.length) {
        carregarPergunta();
      } else {
        mostrarResultadoQuiz();
      }
    }

    function mostrarResultadoQuiz() {
      quizPergunta.textContent = "Resultado do quiz";
      quizOpcoes.innerHTML = "";

      quizResultado.innerHTML = `
        Você fez ${pontuacaoQuiz} de ${perguntasQuiz.length} pontos.<br><br>
        Não importa a pontuação, o prêmio é continuar vivendo nossa história juntos. ❤️
        <br><br>
        <button class="botao-principal" onclick="reiniciarQuiz()">Jogar de novo</button>
      `;
    }

    function reiniciarQuiz() {
      perguntaAtual = 0;
      pontuacaoQuiz = 0;
      carregarPergunta();
    }

    carregarPergunta();

    /* =====================================================
       JOGO DE CLICAR EM CORAÇÕES
       ===================================================== */

    let pontos = 0;
    let tempo = 20;
    let jogoAtivo = false;
    let intervaloTempo;
    let intervaloCoracoes;

    const areaJogo = document.getElementById("areaJogo");
    const pontosTexto = document.getElementById("pontos");
    const tempoTexto = document.getElementById("tempo");
    const mensagemFinalJogo = document.getElementById("mensagemFinalJogo");

    function iniciarJogo() {
      pontos = 0;
      tempo = 20;
      jogoAtivo = true;

      pontosTexto.textContent = pontos;
      tempoTexto.textContent = tempo;
      mensagemFinalJogo.textContent = "";
      areaJogo.innerHTML = "";

      clearInterval(intervaloTempo);
      clearInterval(intervaloCoracoes);

      intervaloTempo = setInterval(() => {
        tempo--;
        tempoTexto.textContent = tempo;

        if (tempo <= 0) {
          finalizarJogo();
        }
      }, 1000);

      intervaloCoracoes = setInterval(() => {
        criarCoracaoDoJogo();
      }, 650);
    }

    function criarCoracaoDoJogo() {
      if (!jogoAtivo) return;

      const coracao = document.createElement("div");
      coracao.classList.add("coracao-jogo");
      coracao.textContent = "❤️";

      const larguraArea = areaJogo.clientWidth;
      const alturaArea = areaJogo.clientHeight;

      const x = Math.random() * (larguraArea - 45);
      const y = Math.random() * (alturaArea - 45);

      coracao.style.left = x + "px";
      coracao.style.top = y + "px";

      coracao.addEventListener("click", () => {
        pontos++;
        pontosTexto.textContent = pontos;
        coracao.remove();
      });

      areaJogo.appendChild(coracao);

      setTimeout(() => {
        coracao.remove();
      }, 1300);
    }

    function finalizarJogo() {
      jogoAtivo = false;
      clearInterval(intervaloTempo);
      clearInterval(intervaloCoracoes);
      areaJogo.innerHTML = "";

      mensagemFinalJogo.textContent =
        "Você coletou vários corações, mas o meu você já tem faz tempo ❤️";
    }

    /* =====================================================
       CARTINHA
       ===================================================== */

    function abrirCarta() {
      const carta = document.getElementById("cartaTexto");
      carta.classList.toggle("aberta");

      if (carta.classList.contains("aberta")) {
        carta.scrollIntoView({ behavior: "smooth", block: "center" });
      }
    }

    /* =====================================================
       SURPRESA FINAL
       ===================================================== */

    function mostrarSurpresa() {
      const mensagem = document.getElementById("mensagemSurpresa");
      mensagem.classList.add("ativa");
      criarExplosaoCoracoes();
    }

    function criarExplosaoCoracoes() {
      for (let i = 0; i < 18; i++) {
        const coracao = document.createElement("div");
        coracao.textContent = "❤️";
        coracao.style.position = "fixed";
        coracao.style.left = Math.random() * 100 + "vw";
        coracao.style.top = "100vh";
        coracao.style.fontSize = 18 + Math.random() * 22 + "px";
        coracao.style.zIndex = "3000";
        coracao.style.pointerEvents = "none";
        coracao.style.animation = `subirCoracao ${3 + Math.random() * 2}s linear forwards`;

        document.body.appendChild(coracao);

        setTimeout(() => {
          coracao.remove();
        }, 5000);
      }
    }

    /* =====================================================
       ANIMAÇÃO DOS CARDS AO ROLAR A TELA
       ===================================================== */

    const elementosAnimados = document.querySelectorAll(".animar");

    function verificarAnimacaoScroll() {
      elementosAnimados.forEach((elemento) => {
        const posicao = elemento.getBoundingClientRect().top;
        const alturaTela = window.innerHeight * 0.85;

        if (posicao < alturaTela) {
          elemento.classList.add("visivel");
        }
      });
    }

    window.addEventListener("scroll", verificarAnimacaoScroll);
    window.addEventListener("load", verificarAnimacaoScroll);
  </script>
